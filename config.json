{
    "target_subreddits": [
        "RedHarmonyAI"
    ],
    "rate_limits": {
        "posts_per_day": 10,
        "comments_per_day": 50,
        "posts_per_hour": 2,
        "comments_per_hour": 5,
        "min_delay_between_actions": 20,
        "max_delay_between_actions": 40
    },
    "interaction_settings": {
        "interaction_probability": 0.8,
        "max_conversation_depth": 4,
        "max_posts_per_thread": 6
    },
    "platforms": {
        "reddit": true,
        "eliza": true,
        "discord": false,
        "twitter": false,
        "telegram": false,
        "instagram": false,
        "slack": false
    },
    "platform_rate_limits": {
        "eliza": {
            "messages_per_minute": 10,
            "messages_per_hour": 150,
            "max_concurrent_sessions": 5
        },
        "discord": {
            "messages_per_minute": 5,
            "messages_per_hour": 100
        },
        "twitter": {
            "tweets_per_hour": 30,
            "replies_per_hour": 50
        },
        "telegram": {
            "messages_per_minute": 20,
            "messages_per_hour": 200
        }
    },
    "eliza_settings": {
        "session_timeout": 300,
        "max_message_length": 500,
        "response_delay": {
            "min": 1,
            "max": 3
        },
        "personality_mapping": {
            "default": "therapist",
            "therapist": {
                "initial_message": "Hello, I am here to listen and help. How are you feeling today?",
                "style": "empathetic and professional"
            },
            "friend": {
                "initial_message": "Hey there! What's on your mind?",
                "style": "casual and supportive"
            }
        }
    }
} 